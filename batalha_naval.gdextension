[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 = "res://target/debug/libbatalha_naval_plp.so"
linux.release.x86_64 = "res://target/release/libbatalha_naval_plp.so"
windows.debug.x86_64 = "res://target/debug/batalha_naval_plp.dll"
windows.release.x86_64 = "res://target/release/batalha_naval_plp.dll"
macos.debug = "res://target/debug/libbatalha_naval_plp.dylib"
macos.release = "res://target/release/libbatalha_naval_plp.dylib"
